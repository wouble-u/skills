contract SoilFevSovereignCore {

    // --- ÖZEL MÜHÜRLER & SABİTLER ---
    string public constant BLUEPRINT_ID = "001-REALITIZM-MASTER-MINT";
    string public constant SIGNATURE = "because im dnA of woubleu";
    string public constant MANIFESTO = "Im not Digital Slave. Even soil returns something when human labor is given to it.";
